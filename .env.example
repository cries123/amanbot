# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_server_id_for_dev_command_registration

# Channel IDs (right-click channel → Copy ID with Developer Mode on)
CHANNEL_SMC_ALERTS=channel_id_for_smc_alerts
CHANNEL_OPTIONS_FLOW=channel_id_for_options_flow
CHANNEL_IV_ALERTS=channel_id_for_iv_extremes
CHANNEL_ECONOMIC=channel_id_for_economic_calendar
CHANNEL_MOD_LOG=channel_id_for_mod_logs

# Impersonation guard (alert in mod log when name + @ combos match)
IMPERSONATION_GUARD_ENABLED=true
# Comma-separated user IDs to never flag (e.g. real owner accounts)
IMPERSONATION_ALLOWLIST=

# API Keys (Finnhub powers charts, flow, IV, economic calendar & news)
FINNHUB_API_KEY=your_finnhub_api_key

# Optional legacy keys (no longer required)
CHART_IMG_API_KEY=
POLYGON_API_KEY=

# Webhook server (optional — local SMC scanner does not need this)
WEBHOOK_ENABLED=true
WEBHOOK_PORT=3000
WEBHOOK_SECRET=optional_shared_secret_for_tradingview_webhook

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/amanbot

# Optional: TradingView session for Chart-img premium indicators
TRADINGVIEW_SESSION_ID=
TRADINGVIEW_SESSION_ID_SIGN=

# Monitor tuning
OPTIONS_MIN_PREMIUM=25000
OPTIONS_MIN_VOI_RATIO=3
FVG_MIN_GAP_PCT=0.02
EQH_EQL_TOLERANCE=0.05
EQH_EQL_SESSION_BAND=0.40
SMC_TIMEFRAMES=5m,1h,4h
IV_WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,AMZN,META,GOOGL
IV_LOW_THRESHOLD=10
IV_HIGH_THRESHOLD=90

# Cron schedules (America/New_York)
IV_SCAN_CRON=0 9,12,15 * * 1-5
ECONOMIC_WEEKLY_CRON=0 7 * * 1
ECONOMIC_WARNING_CRON=*/5 * * * *
SMC_SCAN_CRON=1,6,11,16,21,26,31,36,41,46,51,56 9-16 * * 1-5
